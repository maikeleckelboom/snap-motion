{
  "name": "@snap-motion/vue",
  "version": "0.1.0-beta.0",
  "private": true,
  "description": "Accessible interruptible Vue carousels, modal lightboxes, and bottom sheets.",
  "keywords": [
    "accessibility",
    "bottom-sheet",
    "carousel",
    "motion",
    "vue"
  ],
  "homepage": "https://github.com/maikeleckelboom/snap-motion#readme",
  "bugs": "https://github.com/maikeleckelboom/snap-motion/issues",
  "license": "MIT",
  "author": "Maikel Eckelboom",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maikeleckelboom/snap-motion.git",
    "directory": "packages/vue"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./bottom-sheet": {
      "types": "./dist/bottom-sheet.d.ts",
      "import": "./dist/bottom-sheet.js"
    },
    "./carousel": {
      "types": "./dist/carousel.d.ts",
      "import": "./dist/carousel.js"
    },
    "./dialog": {
      "types": "./dist/dialog.d.ts",
      "import": "./dist/dialog.js"
    },
    "./localization": {
      "types": "./dist/localization.d.ts",
      "import": "./dist/localization.js"
    },
    "./motion": {
      "types": "./dist/motion.d.ts",
      "import": "./dist/motion.js"
    },
    "./style.css": "./dist/style.css"
  },
  "scripts": {
    "build": "node ../../scripts/clean-package-dist.mjs && vue-tsc -p tsconfig.build.json --declaration --emitDeclarationOnly && node ../../scripts/prepare-vue-declarations.mjs && vite build && node ../../scripts/run-api-extractor.mjs --mode=rollup --package=vue",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@snap-motion/core": "workspace:^",
    "@vueuse/core": "catalog:",
    "motion": "catalog:"
  },
  "devDependencies": {
    "@vue/test-utils": "catalog:",
    "happy-dom": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "vue": "catalog:",
    "vue-tsc": "catalog:"
  },
  "peerDependencies": {
    "vue": ">=3.5.0 <4"
  }
}
