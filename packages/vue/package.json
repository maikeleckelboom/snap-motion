{
  "name": "@snap-motion/vue",
  "version": "0.0.0",
  "private": true,
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "vue-tsc -p tsconfig.build.json --declaration --emitDeclarationOnly && vite build",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@snap-motion/core": "workspace:*",
    "motion": "catalog:",
    "vue": "catalog:"
  },
  "devDependencies": {
    "@vue/test-utils": "catalog:",
    "happy-dom": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "vue-tsc": "catalog:"
  }
}
