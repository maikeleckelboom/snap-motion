{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "endOfLine": "lf",
  "printWidth": 100,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "sortImports": true,
  "sortPackageJson": true,
  "ignorePatterns": [
    "legacy/**",
    "**/dist/**",
    "**/.nuxt/**",
    "**/.output/**",
    "coverage/**",
    "etc/*.api.md",
    "playwright-report/**",
    "test-results/**"
  ]
}
